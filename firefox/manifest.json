{
  "manifest_version": 2,
  "name": "TFTV Dark",
  "version": "1.0",
  "description": "Dark mode and threads-only view for teamfortress.tv",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "permissions": [
    "storage"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "tftv-dark@extension",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "web_accessible_resources": [
    "nerdstars/*.gif"
  ],
  "content_scripts": [
    {
      "matches": ["*://www.teamfortress.tv/*", "*://teamfortress.tv/*"],
      "css": ["content.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
